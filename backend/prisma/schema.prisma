  isOwner Boolean          @default(false) @map("is_owner")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([companyId, userId])
  @@index([userId])
  @@map("company_admins")
}

// ─────────────────────────────────────────────────────────────────────────────
// AGENT MODULE (SESSION 8.2)
// ─────────────────────────────────────────────────────────────────────────────

model Agent {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  // Company context (optional — null = independent agent)
  companyId String?  @map("company_id") @db.Uuid
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // User link
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // REN Number (Malaysia Real Estate Negotiator)
  renNumber String?   @map("ren_number")
  renExpiry DateTime? @map("ren_expiry")

  // Performance stats
  totalListings Int     @default(0) @map("total_listings")
  totalDeals    Int     @default(0) @map("total_deals")
  totalRevenue  Decimal @default(0) @db.Decimal(12, 2) @map("total_revenue")

  // Referral
  referralCode String? @unique @map("referral_code")
  referredBy   String? @map("referred_by") @db.Uuid

  // Status
  status AgentStatus @default(ACTIVE)

  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  agentListings AgentListing[]
  commissions   AgentCommission[]

  @@unique([companyId, userId])
  @@index([companyId, status])
  @@index([referralCode])
  @@map("agents")
}

model AgentListing {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  agentId   String  @map("agent_id") @db.Uuid
  agent     Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  listingId String  @map("listing_id") @db.Uuid
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now()) @map("assigned_at")
  removedAt  DateTime? @map("removed_at")

  @@unique([agentId, listingId])
  @@index([listingId])
  @@map("agent_listings")
}

model AgentCommission {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  // Agent reference
  agentId String @map("agent_id") @db.Uuid
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  // Tenancy reference
  tenancyId String  @map("tenancy_id") @db.Uuid
  tenancy   Tenancy @relation(fields: [tenancyId], references: [id])

  // Commission type
  type CommissionType

  // Financial
  dealValue Decimal @map("deal_value") @db.Decimal(12, 2) // e.g. monthly rent
  rate      Decimal @db.Decimal(5, 2)                     // e.g. 100.00 = 1 month
  amount    Decimal @db.Decimal(12, 2)                     // calculated commission

  // Status
  status     CommissionStatus @default(PENDING)
  approvedBy String?          @map("approved_by") @db.Uuid
  approvedAt DateTime?        @map("approved_at")
  paidAt     DateTime?        @map("paid_at")
  paidRef    String?          @map("paid_ref") // Payment reference / receipt

  // Notes
  notes String?

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([agentId, status])
  @@index([tenancyId])
  @@map("agent_commissions")
}

// ============================================
// AFFILIATE MODULE (Session 8.4)
// ============================================

enum AffiliateType {
  INDIVIDUAL
  COMPANY
}

enum AffiliateStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ReferralType {
  OWNER_REGISTRATION
  TENANT_BOOKING
  AGENT_SIGNUP
}

enum ReferralStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
}

enum AffiliatePayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Affiliate {
  id       String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId String @map("tenant_id") @db.Uuid
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  code String        @unique
  type AffiliateType @default(INDIVIDUAL)

  // Bank details for payouts
  bankName        String? @map("bank_name")
  bankAccount     String? @map("bank_account")
  bankAccountName String? @map("bank_account_name")

  // Stats (denormalized for quick access)
  totalReferrals Int     @default(0) @map("total_referrals")
  totalEarnings  Decimal @default(0) @map("total_earnings") @db.Decimal(12, 2)
  unpaidEarnings Decimal @default(0) @map("unpaid_earnings") @db.Decimal(12, 2)

  // Status
  status AffiliateStatus @default(ACTIVE)

  // Notes
  notes String?

  // Relations
  referrals AffiliateReferral[]
  payouts   AffiliatePayout[]

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([partnerId, userId])
  @@index([code])
  @@index([partnerId, status])
  @@map("affiliates")
}

model AffiliateReferral {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  affiliateId String    @map("affiliate_id") @db.Uuid
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  // What was referred
  referralType ReferralType @map("referral_type")
  referredId   String       @map("referred_id") @db.Uuid // ID of the referred entity (vendor, tenancy, agent)

  // Commission
  commissionRate   Decimal @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount Decimal @map("commission_amount") @db.Decimal(12, 2)

  // Status
  status ReferralStatus @default(PENDING)

  // Tracking
  confirmedAt DateTime? @map("confirmed_at")
  paidAt      DateTime? @map("paid_at")

  // Notes
  notes String?

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

  @@index([affiliateId, status])
  @@index([referredId])
  @@map("affiliate_referrals")
}

model AffiliatePayout {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  affiliateId String    @map("affiliate_id") @db.Uuid
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  amount Decimal              @db.Decimal(12, 2)
  status AffiliatePayoutStatus @default(PENDING)

  // Processing details
  processedAt DateTime? @map("processed_at")
  reference   String?   // Bank transfer ref / receipt number

  // Notes
  notes String?

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

  @@index([affiliateId])
  @@index([status])
  @@map("affiliate_payouts")
}

// ============================================
// LEGAL MODULE (Session 8.5)
// ============================================

model LegalCase {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  // Partner context
  partnerId String @map("tenant_id") @db.Uuid

  // Tenancy reference
  tenancyId String  @map("tenancy_id") @db.Uuid
  tenancy   Tenancy @relation(fields: [tenancyId], references: [id])

  // Case details
  caseNumber  String          @unique @map("case_number")
  status      LegalCaseStatus @default(NOTICE_SENT)
  reason      String          // NON_PAYMENT, BREACH, DAMAGE, OTHER
  description String          @db.Text
  amountOwed  Decimal         @map("amount_owed") @db.Decimal(12, 2)

  // Assigned lawyer
  lawyerId String?      @map("lawyer_id") @db.Uuid
  lawyer   PanelLawyer? @relation(fields: [lawyerId], references: [id])

  // Timeline
  noticeDate     DateTime? @map("notice_date")
  noticeDeadline DateTime? @map("notice_deadline")
  courtDate      DateTime? @map("court_date")
  judgmentDate   DateTime? @map("judgment_date")

  // Resolution
  resolvedAt       DateTime? @map("resolved_at")
  resolution       String?
  settlementAmount Decimal?  @map("settlement_amount") @db.Decimal(12, 2)

  // Notes
  notes String?

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  documents LegalDocument[]

  @@index([partnerId, status])
  @@index([tenancyId])
  @@index([lawyerId])
  @@map("legal_cases")
}

model PanelLawyer {
  id       String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId String @map("tenant_id") @db.Uuid
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  // Profile
  name           String
  firm           String?
  email          String
  phone          String
  specialization String[] @default([])

  isActive Boolean @default(true) @map("is_active")

  // Notes
  notes String?

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  cases LegalCase[]

  @@index([partnerId, isActive])
  @@map("panel_lawyers")
}

model LegalDocument {
  id     String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  caseId String    @map("case_id") @db.Uuid
  case   LegalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Document details
  type     String // NOTICE, RESPONSE, COURT_FILING, JUDGMENT, FIRST_REMINDER, SECOND_REMINDER, LEGAL_NOTICE, TERMINATION_NOTICE
  title    String
  fileName String  @map("file_name")
  fileUrl  String  @map("file_url")

  // Metadata
  generatedBy String? @map("generated_by") // system | manual
  notes       String?

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

  @@index([caseId])
  @@map("legal_documents")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROPERTY MEMBER — Per-Property Access Control
// Assigns users to specific properties with granular roles.
// ─────────────────────────────────────────────────────────────────────────────

enum PropertyRole {
  PROPERTY_ADMIN // Full control of this property
  PROPERTY_MANAGER // Manage tenants, maintenance, billing
  LEASING_MANAGER // Handle applications, viewings, contracts
  MAINTENANCE_STAFF // Maintenance tickets only
  PROPERTY_STAFF // Read-only + limited actions
}

model PropertyMember {
  id        String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId String       @map("tenant_id") @db.Uuid
  listingId String       @map("listing_id") @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  role      PropertyRole @default(PROPERTY_STAFF)
  notes     String?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  removedAt DateTime?    @map("removed_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listingId, userId])
  @@index([userId])
  @@index([listingId])
  @@index([partnerId])
  @@map("property_members")
}
