# =============================================================================
# Zam-Property Web Frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Secrets must NEVER use the NEXT_PUBLIC_ prefix.
# =============================================================================

# =============================================================================
# CLIENT-SIDE (exposed to browser via NEXT_PUBLIC_ prefix)
# =============================================================================

# --- Core ---
# Application environment: local | staging | production
NEXT_PUBLIC_APP_ENV=local

# Backend API base URL (browser-facing)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# WebSocket server URL (Socket.IO connects to root, not /api/v1)
NEXT_PUBLIC_WS_URL=http://localhost:3000

# Portal display name (optional, shown in header / browser tab)
NEXT_PUBLIC_PORTAL_NAME=Zam-Property

# --- Feature Toggles ---
# Enable MSW (Mock Service Worker) for API mocking in development
NEXT_PUBLIC_API_MOCKING=false

# Default partner slug — used as X-Partner-ID fallback when no provider is active
NEXT_PUBLIC_DEFAULT_PARTNER=lamaniaga

# Enable Ops Portal UI (optional administrative tools)
NEXT_PUBLIC_ENABLE_OPS_UI=false

# --- Observability (optional) ---
# Sentry DSN for client-side error tracking
NEXT_PUBLIC_SENTRY_DSN=

# Google Analytics Measurement ID (GA4)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Maps API Key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# =============================================================================
# SERVER-ONLY (NEVER prefix with NEXT_PUBLIC_)
# These are used in Server Components, Route Handlers, and build steps only.
# =============================================================================

# Internal API base URL for server-side requests (SSR, Server Actions, RSC).
# Can point to an internal network address for better performance.
API_INTERNAL_BASE_URL=http://localhost:3000/api/v1

# OpenAPI spec URL for code generation (CI / prebuild step)
OPENAPI_SPEC_URL=http://localhost:3000/api/docs-json

# Sentry auth token — CI only, used for source-map upload
# SENTRY_AUTH_TOKEN=

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# 1. NEVER commit .env.local — it is gitignored.
# 2. Secrets must NEVER use the NEXT_PUBLIC_ prefix.
# 3. For production, set NEXT_PUBLIC_APP_ENV=production.
# 4. For staging/UAT, set NEXT_PUBLIC_APP_ENV=staging.
# 5. API_INTERNAL_BASE_URL can use internal DNS (e.g., http://api:3000/api/v1)
#    to bypass external ingress for server-to-server calls.
# 6. Set NEXT_PUBLIC_API_MOCKING=false in staging and production.
