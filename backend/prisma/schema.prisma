generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuid_ossp(map: "uuid-ossp")]
}

model ChargeEvent {
  id              String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId        String     @map("tenant_id") @db.Uuid
  chargeType      ChargeType @map("charge_type")
  amount          Decimal    @db.Decimal(10, 2)
  currency        String     @default("MYR")
  eventType       String     @map("event_type")
  resourceType    String     @map("resource_type")
  resourceId      String     @map("resource_id") @db.Uuid
  pricingConfigId String?    @map("pricing_config_id") @db.Uuid
  pricingRuleId   String?    @map("pricing_rule_id") @db.Uuid
  metadata        Json?
  processed       Boolean    @default(false)
  processedAt     DateTime?  @map("processed_at")
  invoiceId       String?    @map("invoice_id") @db.Uuid
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([chargeType])
  @@index([eventType])
  @@index([invoiceId])
  @@index([processed])
  @@index([resourceType, resourceId])
  @@index([partnerId])
  @@map("charge_events")
}

model EntitlementSnapshot {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId     String   @unique @map("tenant_id") @db.Uuid
  entitlements Json
  planId       String?  @map("plan_id") @db.Uuid
  overrides    Json?
  computedAt   DateTime @default(now()) @map("computed_at")
  expiresAt    DateTime @map("expires_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  plan   Plan?  @relation(fields: [planId], references: [id])

  @@index([expiresAt])
  @@index([partnerId])
  @@map("entitlement_snapshots")
}

model EventLog {
  id            String   @id @db.Uuid
  eventType     String   @map("event_type")
  eventVersion  String   @default("1.0") @map("event_version")
  partnerId      String?  @map("tenant_id") @db.Uuid
  correlationId String   @map("correlation_id")
  causationId   String?  @map("causation_id") @db.Uuid
  actorType     String   @map("actor_type")
  actorId       String?  @map("actor_id") @db.Uuid
  payload       Json
  metadata      Json?
  occurredAt    DateTime @map("occurred_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([correlationId])
  @@index([eventType, occurredAt])
  @@index([occurredAt])
  @@index([partnerId, occurredAt])
  @@map("event_logs")
}

model InteractionMessage {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  interactionId String   @map("interaction_id") @db.Uuid
  senderType    String   @map("sender_type")
  senderId      String?  @map("sender_id") @db.Uuid
  senderName    String   @map("sender_name")
  message       String
  isInternal    Boolean  @default(false) @map("is_internal")
  createdAt     DateTime @default(now()) @map("created_at")

  interaction Interaction @relation(fields: [interactionId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([interactionId])
  @@map("interaction_messages")
}

model Interaction {
  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId        String            @map("tenant_id") @db.Uuid
  vendorId        String            @map("vendor_id") @db.Uuid
  listingId       String            @map("listing_id") @db.Uuid
  verticalType    String            @map("vertical_type")
  interactionType InteractionType   @map("interaction_type")
  contactName     String            @map("contact_name")
  contactEmail    String            @map("contact_email")
  contactPhone    String?           @map("contact_phone")
  message         String?
  bookingData     Json?             @map("booking_data")
  status          InteractionStatus @default(NEW)
  source          String            @default("web")
  referrer        String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  contactedAt     DateTime?         @map("contacted_at")
  closedAt        DateTime?         @map("closed_at")

  messages InteractionMessage[]
  listing  Listing              @relation(fields: [listingId], references: [id])
  partner   Partner               @relation(fields: [partnerId], references: [id])
  vendor   Vendor               @relation(fields: [vendorId], references: [id])

  @@index([createdAt])
  @@index([listingId])
  @@index([status])
  @@index([partnerId])
  @@index([vendorId])
  @@map("interactions")
}

model Invoice {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partnerId         String        @map("tenant_id") @db.Uuid
  externalId       String        @map("external_id")
  externalProvider String        @map("external_provider")
  subscriptionId   String?       @map("subscription_id") @db.Uuid
  customerId       String?       @map("customer_id")
  amount           Decimal       @db.Decimal(10, 2)
  currency         String        @default("MYR") @db.VarChar(3)
  status           InvoiceStatus @default(DRAFT)
  dueDate          DateTime?     @map("due_date")
  paidAt           DateTime?     @map("paid_at")
  invoiceUrl       String?       @map("invoice_url")
  invoicePdf       String?       @map("invoice_pdf")
  metadata         Json?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  partner       Partner        @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([externalId])
  @@index([status])
  @@index([subscriptionId])
  @@index([partnerId])
  @@map("invoices")
}

model ListingMedia {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId         String          @map("tenant_id") @db.Uuid
  listingId        String          @map("listing_id") @db.Uuid
  filename         String
  mimeType         String          @map("mime_type")
  size             Int
  mediaType        MediaType       @default(IMAGE) @map("media_type")
  storageKey       String          @unique @map("storage_key")
  cdnUrl           String?         @map("cdn_url")
  thumbnailKey     String?         @map("thumbnail_key")
  thumbnailUrl     String?         @map("thumbnail_url")
  processingStatus String          @default("pending") @map("processing_status")
  metadata         Json?
  visibility       MediaVisibility @default(PUBLIC)
  sortOrder        Int             @default(0) @map("sort_order")
  isPrimary        Boolean         @default(false) @map("is_primary")
  altText          String?         @map("alt_text")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  deletedAt        DateTime?       @map("deleted_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([mediaType])
  @@index([partnerId])
  @@map("listing_media")
}

model Listing {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId      String        @map("tenant_id") @db.Uuid
  vendorId      String        @map("vendor_id") @db.Uuid
  verticalType  String        @map("vertical_type")
  schemaVersion String        @default("1.0") @map("schema_version")
  title         String
  description   String?
  slug          String
  price         Decimal?      @db.Decimal(15, 2)
  currency      String        @default("MYR")
  priceType     String?       @map("price_type")
  location      Json?
  attributes    Json          @default("{}")
  status        ListingStatus @default(DRAFT)
  publishedAt   DateTime?     @map("published_at")
  expiresAt     DateTime?     @map("expires_at")
  isFeatured      Boolean        @default(false) @map("is_featured")
  featuredUntil   DateTime?      @map("featured_until")
  viewCount       Int            @default(0) @map("view_count")
  managementType  ManagementType @default(SELF_MANAGED) @map("management_type")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  interactions Interaction[]
  media        ListingMedia[]
  stats        ListingStats[]
  partner       Partner         @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  vendor       Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  reviews      Review[]

  // Property Management relations
  tenancies Tenancy[]
  propertyMembers PropertyMember[]

  // Agent assignment
  agentListings AgentListing[]

  // Saved by customers
  savedByUsers SavedListing[]

  @@unique([partnerId, slug])
  @@index([expiresAt])
  @@index([isFeatured])
  @@index([publishedAt])
  @@index([status])
  @@index([partnerId])
  @@index([vendorId])
  @@index([verticalType])
  @@map("listings")
}

// ─────────────────────────────────────────────────────────────────────────────
// ANALYTICS (PART 21)
// Daily, pre-aggregated counters. Written asynchronously via BullMQ (analytics.process).
// ─────────────────────────────────────────────────────────────────────────────

model ListingStats {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId       String   @map("tenant_id") @db.Uuid
  listingId      String   @map("listing_id") @db.Uuid
  vendorId       String   @map("vendor_id") @db.Uuid
  verticalType   String   @map("vertical_type")
  date           DateTime @db.Date
  viewsCount     Int      @default(0) @map("views_count")
  inquiriesCount Int      @default(0) @map("inquiries_count")
  leadsCount     Int      @default(0) @map("leads_count")
  enquiriesCount Int      @default(0) @map("enquiries_count")
  bookingsCount  Int      @default(0) @map("bookings_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  partner  Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([partnerId, listingId, date])
  @@index([partnerId, date])
  @@index([vendorId, date])
  @@index([listingId, date])
  @@index([verticalType, date])
  @@map("listing_stats")
}

model VendorStats {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId       String   @map("tenant_id") @db.Uuid
  vendorId       String   @map("vendor_id") @db.Uuid
  date           DateTime @db.Date
  viewsCount     Int      @default(0) @map("views_count")
  inquiriesCount Int      @default(0) @map("inquiries_count")
  leadsCount     Int      @default(0) @map("leads_count")
  enquiriesCount Int      @default(0) @map("enquiries_count")
  bookingsCount  Int      @default(0) @map("bookings_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([partnerId, vendorId, date])
  @@index([partnerId, date])
  @@index([vendorId, date])
  @@map("vendor_stats")
}

model Media {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId         String           @map("tenant_id") @db.Uuid
  ownerType        String           @map("owner_type")
  ownerId          String           @map("owner_id") @db.Uuid
  filename         String
  mimeType         String           @map("mime_type")
  size             Int
  mediaType        MediaType        @map("media_type")
  storageKey       String           @unique @map("storage_key")
  cdnUrl           String?          @map("cdn_url")
  thumbnailKey     String?          @map("thumbnail_key")
  thumbnailUrl     String?          @map("thumbnail_url")
  processingStatus ProcessingStatus @default(PENDING) @map("processing_status")
  metadata         Json?
  visibility       MediaVisibility  @default(PUBLIC)
  sortOrder        Int              @default(0) @map("sort_order")
  isPrimary        Boolean          @default(false) @map("is_primary")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")

  @@index([mediaType])
  @@index([ownerType, ownerId])
  @@index([storageKey])
  @@index([partnerId])
  @@map("media")
}

model NotificationPreference {
  id               String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId           String              @map("user_id") @db.Uuid
  notificationType NotificationType    @map("notification_type")
  channel          NotificationChannel
  enabled          Boolean             @default(true)
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationType, channel])
  @@index([userId])
  @@map("notification_preferences")
}

model NotificationTemplate {
  id           String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId     String              @map("tenant_id") @db.Uuid
  type         NotificationType
  channel      NotificationChannel
  name         String
  description  String?
  subject      String?
  bodyTemplate String              @map("body_template")
  locale       String              @default("en")
  isActive     Boolean             @default(true) @map("is_active")
  isDefault    Boolean             @default(false) @map("is_default")
  variables    Json?
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  partner        Partner         @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@unique([partnerId, type, channel, locale])
  @@index([channel])
  @@index([isActive])
  @@index([partnerId])
  @@index([type])
  @@map("notification_templates")
}

model Notification {
  id           String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId     String              @map("tenant_id") @db.Uuid
  userId       String              @map("user_id") @db.Uuid
  type         NotificationType
  channel      NotificationChannel
  status       NotificationStatus  @default(PENDING)
  title        String
  body         String
  data         Json?
  sentAt       DateTime?           @map("sent_at")
  readAt       DateTime?           @map("read_at")
  failedAt     DateTime?           @map("failed_at")
  errorMessage String?             @map("error_message")
  templateId   String?             @map("template_id") @db.Uuid
  eventId      String?             @map("event_id")
  resourceType String?             @map("resource_type")
  resourceId   String?             @map("resource_id") @db.Uuid
  retryCount   Int                 @default(0) @map("retry_count")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  template NotificationTemplate? @relation(fields: [templateId], references: [id])
  partner   Partner                @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([channel])
  @@index([createdAt])
  @@index([status])
  @@index([partnerId])
  @@index([type])
  @@index([userId])
  @@map("notifications")
}

model PaymentEvent {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partnerId         String    @map("tenant_id") @db.Uuid
  externalId       String    @unique @map("external_id")
  externalProvider String    @map("external_provider")
  eventType        String    @map("event_type")
  resourceType     String    @map("resource_type")
  resourceId       String    @map("resource_id")
  processed        Boolean   @default(false)
  processedAt      DateTime? @map("processed_at")
  payload          Json
  error            String?
  retryCount       Int       @default(0) @map("retry_count")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([eventType])
  @@index([externalId])
  @@index([processed])
  @@index([partnerId])
  @@map("payment_events")
}

model PaymentMethod {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partnerId         String   @map("tenant_id") @db.Uuid
  externalId       String   @map("external_id")
  externalProvider String   @map("external_provider")
  type             String
  last4            String?
  brand            String?
  expiryMonth      Int?     @map("expiry_month")
  expiryYear       Int?     @map("expiry_year")
  isDefault        Boolean  @default(false) @map("is_default")
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([externalId])
  @@index([isDefault])
  @@index([partnerId])
  @@map("payment_methods")
}

model Plan {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String
  slug         String   @unique
  description  String?
  priceMonthly Decimal? @map("price_monthly") @db.Decimal(10, 2)
  priceYearly  Decimal? @map("price_yearly") @db.Decimal(10, 2)
  currency     String   @default("MYR")
  entitlements Json
  isActive     Boolean  @default(true) @map("is_active")
  isPublic     Boolean  @default(true) @map("is_public")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subscriptions        Subscription[]
  entitlementSnapshots EntitlementSnapshot[]

  @@index([isActive])
  @@index([slug])
  @@map("plans")
}

model PricingConfig {
  id          String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId    String       @map("tenant_id") @db.Uuid
  model       PricingModel
  name        String
  description String?
  isActive    Boolean      @default(true) @map("is_active")
  config      Json
  verticalId  String?      @map("vertical_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  partner Partner        @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  rules  PricingRule[]

  @@index([isActive])
  @@index([model])
  @@index([partnerId])
  @@index([verticalId])
  @@map("pricing_configs")
}

model PricingRule {
  id              String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  pricingConfigId String     @map("pricing_config_id") @db.Uuid
  name            String
  description     String?
  eventType       String     @map("event_type")
  chargeType      ChargeType @map("charge_type")
  amount          Decimal    @db.Decimal(10, 2)
  currency        String     @default("MYR")
  conditions      Json?
  isActive        Boolean    @default(true) @map("is_active")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  pricingConfig PricingConfig @relation(fields: [pricingConfigId], references: [id], onDelete: Cascade)

  @@index([eventType])
  @@index([isActive])
  @@index([pricingConfigId])
  @@map("pricing_rules")
}

model Review {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId       String       @map("tenant_id") @db.Uuid
  targetType     String       @map("target_type")
  targetId       String       @map("target_id") @db.Uuid
  verticalType   String       @map("vertical_type")
  reviewerRef    String       @map("reviewer_ref")
  rating         Int
  title          String?
  content        String?
  status         ReviewStatus @default(PENDING)
  moderatedAt    DateTime?    @map("moderated_at")
  moderatedBy    String?      @map("moderated_by") @db.Uuid
  moderationNote String?      @map("moderation_note")
  responseText   String?      @map("response_text")
  respondedAt    DateTime?    @map("responded_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  vendorId       String?      @map("vendor_id") @db.Uuid
  listingId      String?      @map("listing_id") @db.Uuid

  listing Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)
  partner  Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  vendor  Vendor?  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([rating])
  @@index([status])
  @@index([targetType, targetId])
  @@index([partnerId])
  @@map("reviews")
}

model Subscription {
  id                 String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId           String             @unique @map("tenant_id") @db.Uuid
  planId             String             @map("plan_id") @db.Uuid
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
  externalId         String?            @map("external_id")
  externalProvider   String?            @map("external_provider")
  overrides          Json?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  cancelledAt        DateTime?          @map("cancelled_at")

  invoices Invoice[]
  plan     Plan      @relation(fields: [planId], references: [id])
  partner   Partner    @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@index([status])
  @@index([partnerId])
  @@map("subscriptions")
}

model PartnerDomain {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId  String   @map("tenant_id") @db.Uuid
  domain    String   @unique
  isPrimary Boolean  @default(false) @map("is_primary")
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@map("tenant_domains")
}

model PartnerSettings {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId  String   @unique @map("tenant_id") @db.Uuid
  features  Json     @default("{}")
  locale    String   @default("en")
  currency  String   @default("MYR")
  timezone  String   @default("Asia/Kuala_Lumpur")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@map("tenant_settings")
}

model PartnerVertical {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId        String    @map("tenant_id") @db.Uuid
  verticalId      String    @map("vertical_id") @db.Uuid
  configOverrides Json?     @map("config_overrides")
  customFields    Json?     @map("custom_fields")
  listingLimit    Int?      @map("listing_limit")
  isEnabled       Boolean   @default(true) @map("is_enabled")
  enabledAt       DateTime  @default(now()) @map("enabled_at")
  disabledAt      DateTime? @map("disabled_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  partner   Partner             @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  vertical VerticalDefinition @relation(fields: [verticalId], references: [id], onDelete: Cascade)

  @@unique([partnerId, verticalId])
  @@index([isEnabled])
  @@index([partnerId])
  @@index([verticalId])
  @@map("tenant_verticals")
}

model Partner {
  id               String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name             String
  slug             String       @unique
  status           PartnerStatus @default(ACTIVE)
  enabledVerticals String[]     @default([])
  branding         Json?
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  deletedAt        DateTime?    @map("deleted_at")

  chargeEvents          ChargeEvent[]
  interactions          Interaction[]
  invoices              Invoice[]
  listings              Listing[]
  notificationTemplates NotificationTemplate[]
  notifications         Notification[]
  paymentEvents         PaymentEvent[]
  paymentMethods        PaymentMethod[]
  pricingConfigs        PricingConfig[]
  reviews               Review[]
  subscription          Subscription?
  domains               PartnerDomain[]
  settings              PartnerSettings?
  PartnerVerticals       PartnerVertical[]
  users                 User[]
  vendors               Vendor[]
  listingStats          ListingStats[]
  vendorStats           VendorStats[]
  entitlementSnapshot   EntitlementSnapshot?

  featureFlagOverrides   FeatureFlagOverride[]
  featureFlagUserTargets FeatureFlagUserTarget[]
  experimentOptIns       ExperimentPartnerOptIn[]
  auditLogs              AuditLog[]

  // Property Management relations
  tenants           Tenant[]
  tenancies         Tenancy[]
  contractTemplates ContractTemplate[]
  rentPayments      RentPayment[]
  billingReminders  RentBillingReminder[]
  ownerPayouts      OwnerPayout[]
  companies         Company[]
  affiliates        Affiliate[]
  panelLawyers      PanelLawyer[]
  savedListings     SavedListing[]
  userSettings      UserSettings[]
  propertyMembers   PropertyMember[]

  @@index([slug])
  @@index([status])
  @@map("tenants")
}

model UsageCounter {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId    String   @map("tenant_id") @db.Uuid
  metricKey   String   @map("metric_key")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  count       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([partnerId, metricKey, periodStart])
  @@index([metricKey])
  @@index([periodStart])
  @@index([partnerId])
  @@map("usage_counters")
}

model User {
  id           String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId     String     @map("tenant_id") @db.Uuid
  email        String
  passwordHash String     @map("password_hash")
  fullName     String     @map("full_name")
  phone        String?
  role         Role
  status       UserStatus @default(ACTIVE)
  isSystem     Boolean    @default(false) @map("is_system")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  deletedAt    DateTime?  @map("deleted_at")
  vendorId     String?    @map("vendor_id") @db.Uuid

  notificationPreferences NotificationPreference[]
  notifications           Notification[]
  partner                  Partner                   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  vendor                  Vendor?                  @relation(fields: [vendorId], references: [id])

  featureFlagTargets FeatureFlagUserTarget[]
  tenants            Tenant[]
  companyAdmins      CompanyAdmin[]
  agents             Agent[]
  affiliates         Affiliate[]
  savedListings      SavedListing[]
  settings           UserSettings?
  propertyMembers    PropertyMember[]

  @@unique([partnerId, email])
  @@index([email])
  @@index([status])
  @@index([partnerId])
  @@index([vendorId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// Saved Listings (favourites / bookmarks)
// ---------------------------------------------------------------------------

model SavedListing {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId  String   @map("tenant_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  listingId String   @map("listing_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  partner  Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@index([partnerId])
  @@map("saved_listings")
}

// ---------------------------------------------------------------------------
// User Settings (language, timezone, privacy)
// ---------------------------------------------------------------------------

model UserSettings {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId     String   @map("tenant_id") @db.Uuid
  userId       String   @unique @map("user_id") @db.Uuid
  language     String   @default("en")
  timezone     String   @default("Asia/Kuala_Lumpur")
  showProfile  Boolean  @default(true) @map("show_profile")
  showEmail    Boolean  @default(false) @map("show_email")
  showPhone    Boolean  @default(false) @map("show_phone")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@map("user_settings")
}

model VendorProfile {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vendorId       String   @unique @map("vendor_id") @db.Uuid
  businessRegNo  String?  @map("business_reg_no")
  taxId          String?  @map("tax_id")
  addressLine1   String?  @map("address_line1")
  addressLine2   String?  @map("address_line2")
  city           String?
  state          String?
  postalCode     String?  @map("postal_code")
  country        String?  @default("MY")
  logoUrl        String?  @map("logo_url")
  bannerUrl      String?  @map("banner_url")
  socialLinks    Json?    @map("social_links")
  operatingHours Json?    @map("operating_hours")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_profiles")
}

model VendorSettings {
  id                  String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vendorId            String   @unique @map("vendor_id") @db.Uuid
  emailNotifications  Boolean  @default(true) @map("email_notifications")
  smsNotifications    Boolean  @default(false) @map("sms_notifications")
  leadNotifications   Boolean  @default(true) @map("lead_notifications")
  autoResponseEnabled Boolean  @default(false) @map("auto_response_enabled")
  autoResponseMessage String?  @map("auto_response_message")
  showPhone           Boolean  @default(true) @map("show_phone")
  showEmail           Boolean  @default(true) @map("show_email")
  settings            Json?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_settings")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROPERTY MANAGEMENT MODELS (Phase 5+)
// Tenant, Tenancy, Contract, Deposit management
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  // Link to existing User
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Partner context (SaaS multi-tenancy)
  partnerId String @map("tenant_id") @db.Uuid
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  // Profile
  status         TenantStatus @default(PENDING)
  employmentType String?        @map("employment_type") // EMPLOYED, SELF_EMPLOYED, STUDENT, RETIRED
  monthlyIncome  Decimal?       @map("monthly_income") @db.Decimal(12, 2)
  employer       String?

  // Verification
  icNumber       String? @map("ic_number") // Malaysian IC
  passportNumber String? @map("passport_number")
  icVerified     Boolean @default(false) @map("ic_verified")
  incomeVerified Boolean @default(false) @map("income_verified")

  // Emergency Contact
  emergencyName     String? @map("emergency_name")
  emergencyPhone    String? @map("emergency_phone")
  emergencyRelation String? @map("emergency_relation")

  // Screening
  screeningScore Int?      @map("screening_score")
  screeningNotes String?   @map("screening_notes")
  screenedAt     DateTime? @map("screened_at")
  screenedBy     String?   @map("screened_by") @db.Uuid

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenancies Tenancy[]
  documents TenantDocument[]

  @@unique([userId, partnerId])
  @@index([partnerId, status])
  @@index([userId])
  @@map("occupants")
}

model TenantDocument {
  id       String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId String @map("occupant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  type     String // IC_FRONT, IC_BACK, PAYSLIP, BANK_STATEMENT, EMPLOYMENT_LETTER
  fileName String @map("file_name")
  fileUrl  String @map("file_url")
  fileSize Int    @map("file_size")
  mimeType String @map("mime_type")

  verified   Boolean   @default(false)
  verifiedAt DateTime? @map("verified_at")
  verifiedBy String?   @map("verified_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId, type])
  @@map("occupant_documents")
}

model VendorDocument {
  id       String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vendorId String @map("vendor_id") @db.Uuid
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  type     String // IC_FRONT, IC_BACK, BUSINESS_LICENSE, SSM, BANK_STATEMENT
  fileName String @map("file_name")
  fileUrl  String @map("file_url")
  fileSize Int    @map("file_size")
  mimeType String @map("mime_type")

  verified   Boolean   @default(false)
  verifiedAt DateTime? @map("verified_at")
  verifiedBy String?   @map("verified_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  @@index([vendorId, type])
  @@map("vendor_documents")
}

model Tenancy {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  // Context
  partnerId String @map("tenant_id") @db.Uuid
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  // Property & Parties
  listingId String  @map("listing_id") @db.Uuid
  listing   Listing @relation(fields: [listingId], references: [id])

  ownerId String @map("owner_id") @db.Uuid // Vendor who owns the property
  owner   Vendor @relation("TenancyOwner", fields: [ownerId], references: [id])

  tenantId String   @map("occupant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  // Status
  status TenancyStatus @default(DRAFT)

  // Dates
  applicationDate DateTime  @default(now()) @map("application_date")
  moveInDate      DateTime? @map("move_in_date")
  moveOutDate     DateTime? @map("move_out_date")
  leaseStartDate  DateTime? @map("lease_start_date")
  leaseEndDate    DateTime? @map("lease_end_date")
  actualEndDate   DateTime? @map("actual_end_date")

  // Financial Terms
  monthlyRent     Decimal  @map("monthly_rent") @db.Decimal(12, 2)
  securityDeposit Decimal  @map("security_deposit") @db.Decimal(12, 2)
  utilityDeposit  Decimal? @map("utility_deposit") @db.Decimal(12, 2)
  keyDeposit      Decimal? @map("key_deposit") @db.Decimal(12, 2)

  // Billing
  billingDay     Int      @default(1) @map("billing_day") // Day of month to generate bill
  paymentDueDay  Int      @default(7) @map("payment_due_day") // Days after billing to pay
  lateFeePercent Decimal? @map("late_fee_percent") @db.Decimal(5, 2)

  // Metadata
  notes String?

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  contract      Contract?
  deposits      Deposit[]
  billings      RentBilling[]
  statusHistory TenancyStatusHistory[]
  maintenance   Maintenance[]
  inspections   Inspection[]
  claims        Claim[]
  agentCommissions AgentCommission[]
  legalCases    LegalCase[]

  @@index([partnerId, status])
  @@index([ownerId])
  @@index([tenantId])
  @@index([listingId])
  @@map("tenancies")
}

model TenancyStatusHistory {
  id        String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenancyId String  @map("tenancy_id") @db.Uuid
  tenancy   Tenancy @relation(fields: [tenancyId], references: [id], onDelete: Cascade)

  fromStatus TenancyStatus? @map("from_status")
  toStatus   TenancyStatus  @map("to_status")
  reason     String?
  changedBy  String         @map("changed_by") @db.Uuid
  changedAt  DateTime       @default(now()) @map("changed_at")

  @@index([tenancyId])
  @@map("tenancy_status_history")
}

model Contract {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  tenancyId String  @unique @map("tenancy_id") @db.Uuid
  tenancy   Tenancy @relation(fields: [tenancyId], references: [id], onDelete: Cascade)

  // Contract Details
  contractNumber String  @unique @map("contract_number")
  templateId     String? @map("template_id") @db.Uuid // ContractTemplate reference

  status ContractStatus @default(DRAFT)

  // Dates
  startDate  DateTime  @map("start_date")
  endDate    DateTime  @map("end_date")
  signedDate DateTime? @map("signed_date")

  // Owner Signature
  ownerSignedAt     DateTime? @map("owner_signed_at")
  ownerSignedBy     String?   @map("owner_signed_by") @db.Uuid
  ownerSignatureUrl String?   @map("owner_signature_url")

  // Tenant Signature
  tenantSignedAt     DateTime? @map("occupant_signed_at")
  tenantSignedBy     String?   @map("occupant_signed_by") @db.Uuid
  tenantSignatureUrl String?   @map("occupant_signature_url")

  // Document
  documentUrl  String? @map("document_url") // Generated PDF
  documentHash String? @map("document_hash") // SHA256 for integrity

  // Terms (JSON for flexibility)
  terms Json @default("{}") // { rentAmount, deposit, utilities, pets, ... }

  // Renewal
  renewedFromId String?   @unique @map("renewed_from_id") @db.Uuid
  renewedFrom   Contract? @relation("ContractRenewal", fields: [renewedFromId], references: [id])
  renewedTo     Contract? @relation("ContractRenewal")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([contractNumber])
  @@map("contracts")
}

model ContractTemplate {
  id       String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  partnerId String @map("tenant_id") @db.Uuid
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  name        String
  description String?
  content     String  @db.Text // HTML or Markdown template
  variables   Json    @default("[]") // Available merge fields

  isDefault Boolean @default(false) @map("is_default")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([partnerId, isActive])
  @@map("contract_templates")
}

model Deposit {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  tenancyId String  @map("tenancy_id") @db.Uuid
  tenancy   Tenancy @relation(fields: [tenancyId], references: [id], onDelete: Cascade)

  // Deposit Details
  type   String // SECURITY, UTILITY, KEY
  amount Decimal @db.Decimal(12, 2)

  status DepositStatus @default(PENDING)

  // Collection
  collectedAt  DateTime? @map("collected_at")
  collectedVia String?   @map("collected_via") // Payment method
  paymentRef   String?   @map("payment_ref")

  // Refund
  refundableAmount Decimal?  @map("refundable_amount") @db.Decimal(12, 2)
  deductions       Decimal?  @db.Decimal(12, 2)
  refundedAmount   Decimal?  @map("refunded_amount") @db.Decimal(12, 2)
  refundedAt       DateTime? @map("refunded_at")
  refundRef        String?   @map("refund_ref")

  // Linked claims for deductions
  deductionClaims Json? @map("deduction_claims") // Array of { claimId, amount }

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenancyId, type])
  @@index([status])
  @@map("deposits")
}

// ─────────────────────────────────────────────────────────────────────────────
// RENT BILLING MODULE (Phase 6)
// Rent billing, line items, and reminders for tenancy invoicing
// Prefixed with "Rent" to avoid collision with infrastructure billing
// ─────────────────────────────────────────────────────────────────────────────

model RentBilling {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  tenancyId String  @map("tenancy_id") @db.Uuid
  tenancy   Tenancy @relation(fields: [tenancyId], references: [id], onDelete: Cascade)

  // Bill Details
  billNumber    String   @unique @map("bill_number")
  billingPeriod DateTime @map("billing_period") // Month being billed (e.g., 2026-03-01)

  status RentBillingStatus @default(DRAFT)

  // Amounts
  rentAmount  Decimal @map("rent_amount") @db.Decimal(12, 2)
  lateFee     Decimal @default(0) @map("late_fee") @db.Decimal(12, 2)
  adjustments Decimal @default(0) @db.Decimal(12, 2) // +/- for claims
  totalAmount Decimal @map("total_amount") @db.Decimal(12, 2)
  paidAmount  Decimal @default(0) @map("paid_amount") @db.Decimal(12, 2)
  balanceDue  Decimal @map("balance_due") @db.Decimal(12, 2)

  // Dates
  issueDate DateTime  @map("issue_date")
  dueDate   DateTime  @map("due_date")
  paidDate  DateTime? @map("paid_date")

  // Relations
  lineItems RentBillingLineItem[]
  reminders RentBillingReminder[]
  payments  RentPayment[]

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenancyId, billingPeriod])
  @@index([status, dueDate])
  @@map("rent_billings")
}

model RentPayment {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  // Context
  partnerId String @map("tenant_id") @db.Uuid
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  // Billing reference
  billingId String      @map("billing_id") @db.Uuid
  billing   RentBilling @relation(fields: [billingId], references: [id], onDelete: Cascade)

  // Payment details
  paymentNumber String           @unique @map("payment_number")
  amount        Decimal          @db.Decimal(12, 2)
  status        RentPaymentStatus @default(PENDING)
  method        String           // CARD, FPX, BANK_TRANSFER, CASH, OTHER
  currency      String           @default("MYR") @db.VarChar(3)

  // Gateway references
  gatewayId     String?  @map("gateway_id") // Stripe PaymentIntent ID
  gatewayData   Json?    @map("gateway_data") // Full gateway response
  clientSecret  String?  @map("client_secret") // Stripe client secret for frontend

  // Reference & Receipt
  reference     String?  // Bank ref / Transaction ID
  receiptNumber String?  @unique @map("receipt_number")
  receiptUrl    String?  @map("receipt_url")

  // Dates
  paymentDate DateTime? @map("payment_date")
  processedAt DateTime? @map("processed_at")

  // Payer info
  payerName  String? @map("payer_name")
  payerEmail String? @map("payer_email")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([partnerId])
  @@index([billingId])
  @@index([status])
  @@index([gatewayId])
  @@map("rent_payments")
}

model RentBillingLineItem {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  billingId String      @map("billing_id") @db.Uuid
  billing   RentBilling @relation(fields: [billingId], references: [id], onDelete: Cascade)

  description String
  type        String // RENT, UTILITY, LATE_FEE, CLAIM_DEDUCTION, OTHER
  amount      Decimal @db.Decimal(12, 2)

  // Reference to claim if applicable
  claimId String? @map("claim_id") @db.Uuid

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

  @@index([billingId])
  @@map("rent_billing_line_items")
}

model RentBillingReminder {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  // Context
  partnerId String @map("tenant_id") @db.Uuid
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  billingId String      @map("billing_id") @db.Uuid
  billing   RentBilling @relation(fields: [billingId], references: [id], onDelete: Cascade)

  // Reminder details
  sequence Int // 1 = 3 days before due, 2 = on due date, 3 = 7 days overdue, 4 = legal notice (14 days overdue)
  type     String // EMAIL, SMS, LETTER, LEGAL_NOTICE
  status   String @default("SENT") // SENT, DELIVERED, FAILED, ACKNOWLEDGED
  sentAt   DateTime @map("sent_at")
  sentTo   String   @map("sent_to")

  // Response tracking
  response    String?
  respondedAt DateTime? @map("responded_at")

  // Escalation
  escalatedAt DateTime? @map("escalated_at") // Set when flagged for legal action
  escalatedTo String?   @map("escalated_to") // Legal team / reference

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

  @@index([partnerId])
  @@index([billingId])
  @@index([billingId, sequence])
  @@map("rent_billing_reminders")
}

// ─────────────────────────────────────────────────────────────────────────────
// OWNER PAYOUT MODULE (Phase 6.6)
// Calculates and tracks payouts to property owners
// ─────────────────────────────────────────────────────────────────────────────

model OwnerPayout {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  // Context
  partnerId String @map("tenant_id") @db.Uuid
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  // Owner (Vendor)
  ownerId String @map("owner_id") @db.Uuid
  owner   Vendor @relation(fields: [ownerId], references: [id])

  // Payout Details
  payoutNumber String       @unique @map("payout_number")
  periodStart  DateTime     @map("period_start")
  periodEnd    DateTime     @map("period_end")
  status       PayoutStatus @default(PENDING)

  // Amounts
  grossRental     Decimal @map("gross_rental") @db.Decimal(12, 2)
  platformFee     Decimal @map("platform_fee") @db.Decimal(12, 2)
  maintenanceCost Decimal @default(0) @map("maintenance_cost") @db.Decimal(12, 2)
  otherDeductions Decimal @default(0) @map("other_deductions") @db.Decimal(12, 2)
  netPayout       Decimal @map("net_payout") @db.Decimal(12, 2)

  // Line Items
  lineItems PayoutLineItem[]

  // Bank Details (snapshot at payout time)
  bankName        String? @map("bank_name")
  bankAccount     String? @map("bank_account")
  bankAccountName String? @map("bank_account_name")

  // Processing
  approvedBy    String?   @map("approved_by") @db.Uuid
  approvedAt    DateTime? @map("approved_at")
  processedAt   DateTime? @map("processed_at")
  bankReference String?   @map("bank_reference")
  bankFile      String?   @map("bank_file") // Bulk payment file URL

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([partnerId])
  @@index([ownerId, periodStart])
  @@index([status])
  @@map("owner_payouts")
}

model PayoutLineItem {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  payoutId String      @map("payout_id") @db.Uuid
  payout   OwnerPayout @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  tenancyId String  @map("tenancy_id") @db.Uuid
  billingId String? @map("billing_id") @db.Uuid

  type        String // RENTAL, PLATFORM_FEE, MAINTENANCE, CLAIM_DEDUCTION, OTHER
  description String
  amount      Decimal @db.Decimal(12, 2)

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")

