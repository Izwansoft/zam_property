// ============================================
// MAINTENANCE MODULE
// ============================================

model Maintenance {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  // Context
  tenancyId String  @map("tenancy_id") @db.Uuid
  tenancy   Tenancy @relation(fields: [tenancyId], references: [id])

  // Request Details
  ticketNumber String @unique @map("ticket_number")
  title        String
  description  String @db.Text
  category     String // PLUMBING, ELECTRICAL, APPLIANCE, STRUCTURAL, OTHER
  location     String? // Room/area in property

  status   MaintenanceStatus   @default(OPEN)
  priority MaintenancePriority @default(MEDIUM)

  // Reporter
  reportedBy String   @map("reported_by") @db.Uuid
  reportedAt DateTime @default(now()) @map("reported_at")

  // Verification
  verifiedBy        String?   @map("verified_by") @db.Uuid
  verifiedAt        DateTime? @map("verified_at")
  verificationNotes String?   @map("verification_notes")

  // Assignment
  assignedTo     String?   @map("assigned_to") // Could be vendor staff or external contractor
  assignedAt     DateTime? @map("assigned_at")
  contractorName String?   @map("contractor_name") // External contractor name
  contractorPhone String?  @map("contractor_phone") // External contractor phone

  // Workflow timestamps
  startedAt DateTime? @map("started_at") // When work started (IN_PROGRESS)
  closedAt  DateTime? @map("closed_at")  // When ticket was closed

  // Resolution
  resolvedAt DateTime? @map("resolved_at")
  resolvedBy String?   @map("resolved_by") @db.Uuid
  resolution String?

  // Cost
  estimatedCost Decimal? @map("estimated_cost") @db.Decimal(12, 2)
  actualCost    Decimal? @map("actual_cost") @db.Decimal(12, 2)
  paidBy        String?  @map("paid_by") // OWNER, TENANT, SHARED

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  attachments MaintenanceAttachment[]
  updates     MaintenanceUpdate[]
  claim       Claim?

  @@index([tenancyId, status])
  @@index([status, priority])
  @@map("maintenance_tickets")
}

model MaintenanceAttachment {
  id            String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  maintenanceId String      @map("maintenance_id") @db.Uuid
  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)

  type     String // IMAGE, VIDEO, DOCUMENT
  fileName String @map("file_name")
  fileUrl  String @map("file_url")
  fileSize Int    @map("file_size")
  mimeType String @map("mime_type")

  uploadedBy String   @map("uploaded_by") @db.Uuid
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  @@index([maintenanceId])
  @@map("maintenance_attachments")
}

model MaintenanceUpdate {
  id            String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  maintenanceId String      @map("maintenance_id") @db.Uuid
  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)

  message    String  @db.Text
  isInternal Boolean @default(false) @map("is_internal") // Hidden from tenant

  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  @@index([maintenanceId])
  @@map("maintenance_updates")
}

// ============================================
// INSPECTION MODELS (Session 7.3)
// ============================================

model Inspection {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  // Context
  tenancyId String  @map("tenancy_id") @db.Uuid
  tenancy   Tenancy @relation(fields: [tenancyId], references: [id])

  // Inspection Details
  type           InspectionType
  status         InspectionStatus @default(SCHEDULED)
  scheduledDate  DateTime?        @map("scheduled_date")
  scheduledTime  String?          @map("scheduled_time") // e.g. "10:00-12:00"

  // Video Inspection
  videoRequested   Boolean   @default(false) @map("video_requested")
  videoRequestedAt DateTime? @map("video_requested_at")
  videoUrl         String?   @map("video_url")
  videoSubmittedAt DateTime? @map("video_submitted_at")

  // Onsite Inspection
  onsiteRequired  Boolean  @default(false) @map("onsite_required")
  onsiteDate      DateTime? @map("onsite_date")
  onsiteInspector String?  @map("onsite_inspector")

  // Report
  reportUrl     String? @map("report_url")
  overallRating Int?    @map("overall_rating") // 1-5
  notes         String? @db.Text

  // Completion
  completedAt DateTime? @map("completed_at")
  completedBy String?   @map("completed_by") @db.Uuid

  // Audit
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  checklist InspectionItem[]

  @@index([tenancyId, type])
  @@index([status])
  @@map("inspections")
}

model InspectionItem {
  id           String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  inspectionId String     @map("inspection_id") @db.Uuid
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  category  String  // BEDROOM, BATHROOM, KITCHEN, LIVING, EXTERIOR, OTHER
  item      String  // Wall condition, Floor condition, etc.
  condition String? // EXCELLENT, GOOD, FAIR, POOR, DAMAGED
  notes     String?
  photoUrls Json?   @map("photo_urls") // Array of image URL strings

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([inspectionId])
  @@map("inspection_items")
}

// ============================================
// CLAIM MODULE (Session 7.5)
// ============================================

model Claim {
  id String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid

  // Context
  tenancyId String  @map("tenancy_id") @db.Uuid
  tenancy   Tenancy @relation(fields: [tenancyId], references: [id])

  // Optional link to maintenance ticket
  maintenanceId String?      @unique @map("maintenance_id") @db.Uuid
  maintenance   Maintenance? @relation(fields: [maintenanceId], references: [id])

  // Claim Details
  claimNumber String      @unique @map("claim_number")
  type        ClaimType
  status      ClaimStatus @default(SUBMITTED)

  title       String
  description String @db.Text

  // Amounts
  claimedAmount  Decimal  @map("claimed_amount") @db.Decimal(12, 2)
  approvedAmount Decimal? @map("approved_amount") @db.Decimal(12, 2)

  // Submitted by (OWNER or TENANT userId)
  submittedBy   String   @map("submitted_by") @db.Uuid
  submittedRole String   @map("submitted_role") // OWNER or TENANT
  submittedAt   DateTime @default(now()) @map("submitted_at")

  // Review
  reviewedBy  String?   @map("reviewed_by") @db.Uuid
  reviewedAt  DateTime? @map("reviewed_at")
  reviewNotes String?   @map("review_notes") @db.Text

  // Settlement
  settledAt        DateTime? @map("settled_at")
  settlementMethod String?   @map("settlement_method") // DEPOSIT_DEDUCTION, BILLING_DEDUCTION, DIRECT_PAYMENT

  // Dispute
  isDisputed    Boolean   @default(false) @map("is_disputed")
  disputeReason String?   @map("dispute_reason") @db.Text
  disputedAt    DateTime? @map("disputed_at")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  evidence ClaimEvidence[]

  @@index([tenancyId, status])
  @@index([type])
  @@map("claims")
}

model ClaimEvidence {
  id      String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  claimId String @map("claim_id") @db.Uuid
  claim   Claim  @relation(fields: [claimId], references: [id], onDelete: Cascade)

  type        String  // PHOTO, VIDEO, RECEIPT, QUOTE
  fileName    String  @map("file_name")
  fileUrl     String  @map("file_url")
  fileSize    Int?    @map("file_size")
  mimeType    String? @map("mime_type")
  description String?

  uploadedBy String   @map("uploaded_by") @db.Uuid
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  @@index([claimId])
  @@map("claim_evidence")
}

