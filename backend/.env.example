# App
NODE_ENV=development
APP_NAME=zam-property-api
PORT=3000
API_PREFIX=api/v1
SWAGGER_ENABLED=true
LOG_LEVEL=info

# Database (PostgreSQL) - Docker port 5433
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/zam_property?schema=public

# Redis (Cache + BullMQ + Socket.IO adapter) - Docker port 6380
REDIS_URL=redis://localhost:6380

# JWT Auth
JWT_ACCESS_TOKEN_SECRET=change-me-access-dev-only
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_SECRET=change-me-refresh-dev-only
JWT_REFRESH_TOKEN_TTL=30d

# OpenSearch
OPENSEARCH_NODE=http://localhost:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# S3 / Object Storage (MinIO) - Docker port 9002
S3_ENDPOINT=http://localhost:9002
S3_REGION=ap-southeast-1
S3_BUCKET=zam-property
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Socket.IO
SOCKET_IO_REDIS_URL=redis://localhost:6380

# BullMQ
BULLMQ_REDIS_URL=redis://localhost:6380

# Security / CORS (optional)
CORS_ORIGIN=http://localhost:3001
# Stripe Billing (test mode)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder